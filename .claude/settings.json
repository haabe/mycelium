{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "defaultMode": "acceptEdits",
    "allow": [
      "Write(.claude/**)",
      "Edit(.claude/**)",
      "Write(src/**)",
      "Write(scripts/**)",
      "Write(docs/**)",
      "Write(public/**)",
      "Edit(src/**)",
      "Edit(scripts/**)",
      "Edit(docs/**)",
      "Edit(public/**)",
      "Bash(git status:*)",
      "Bash(git diff:*)",
      "Bash(git log:*)",
      "Bash(git add:*)",
      "Bash(git commit:*)",
      "Bash(git checkout:*)",
      "Bash(git branch:*)",
      "Bash(git stash:*)",
      "Bash(git fetch:*)",
      "Bash(git pull:*)",
      "Bash(mkdir:*)",
      "Bash(chmod:*)",
      "WebSearch"
    ],
    "ask": [
      "Bash(git push:*)",
      "Bash(git reset:*)"
    ],
    "deny": [
      "Bash(rm -rf:*)",
      "Bash(sudo:*)",
      "Bash(git push --force:*)"
    ]
  }
}
