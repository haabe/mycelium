{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mycelium.dev/schemas/canvas/content-metrics.schema.json",
  "title": "Content Delivery Metrics Canvas",
  "description": "Delivery metrics for content products (courses, publications, media). Replaces dora-metrics.yml for non-software product types. Measures production cadence, quality, and engagement.",
  "type": "object",
  "properties": {
    "schema_version": {
      "$ref": "_common.schema.json#/$defs/schema_version"
    },
    "publication_cadence": {
      "type": "object",
      "properties": {
        "current": {"type": ["string", "null"]},
        "target": {"type": ["string", "null"]},
        "classification": {
          "type": ["string", "null"],
          "enum": ["consistent", "improving", "declining", null]
        },
        "measurement_period": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "production_lead_time": {
      "type": "object",
      "properties": {
        "current": {"type": ["string", "null"]},
        "target": {"type": ["string", "null"]},
        "bottleneck": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "revision_rate": {
      "type": "object",
      "properties": {
        "current": {"type": ["string", "null"]},
        "target": {"type": ["string", "null"]},
        "recent_revisions": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "completion_rate": {
      "type": "object",
      "properties": {
        "current": {"type": ["string", "null"]},
        "target": {"type": ["string", "null"]},
        "planned_items": {"type": ["string", "integer", "null"]},
        "completed_items": {"type": ["string", "integer", "null"]}
      },
      "additionalProperties": true
    },
    "engagement": {
      "type": "object",
      "properties": {
        "completion_rate": {"type": ["number", "null"]},
        "satisfaction_score": {"type": ["number", "null"]},
        "return_rate": {"type": ["number", "null"]},
        "referral_rate": {"type": ["number", "null"]},
        "drop_off_points": {
          "type": "array",
          "items": {"type": "string"}
        }
      },
      "additionalProperties": true
    },
    "time_to_first_value": {
      "type": "object",
      "properties": {
        "current": {"type": ["string", "null"]},
        "target": {"type": ["string", "null"]},
        "bottleneck": {"type": ["string", "null"]}
      },
      "additionalProperties": true
    },
    "acquisition": {
      "type": "object",
      "properties": {
        "conversion_rate": {"type": ["number", "null"]},
        "cost_per_acquisition": {"type": ["number", "null"]},
        "traffic_to_lead_ratio": {"type": ["number", "null"]},
        "cart_abandonment_rate": {"type": ["number", "null"]}
      },
      "additionalProperties": true
    },
    "revenue": {
      "type": "object",
      "properties": {
        "refund_rate": {"type": ["number", "null"]},
        "customer_lifetime_value": {"type": ["number", "null"]},
        "churn_rate": {"type": ["number", "null"]},
        "net_revenue_retention": {"type": ["number", "null"]}
      },
      "additionalProperties": true
    },
    "quality_review": {
      "type": "object",
      "properties": {
        "sme_reviewed": {"type": "boolean"},
        "accessibility_checked": {"type": "boolean"},
        "fact_checked": {"type": "boolean"},
        "style_consistent": {"type": "boolean"},
        "learning_objectives_met": {"type": "boolean"}
      },
      "additionalProperties": true
    },
    "last_measured": {
      "oneOf": [
        {"$ref": "_common.schema.json#/$defs/iso_timestamp"},
        {"type": "null"}
      ]
    }
  },
  "additionalProperties": true
}
