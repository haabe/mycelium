{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://mycelium.dev/schemas/canvas/go-to-market.schema.json",
  "title": "Go-to-Market Canvas",
  "description": "Lauchengco Loved framework. buyer_personas and competitive_intelligence entries require provenance because positioning evidence matters.",
  "type": "object",
  "properties": {
    "schema_version": {
      "$ref": "_common.schema.json#/$defs/schema_version"
    },
    "buyer_personas": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "name": {"type": "string"},
          "role": {"type": "string"},
          "provenance": {
            "$ref": "_common.schema.json#/$defs/provenance"
          },
          "trace": {
            "$ref": "_common.schema.json#/$defs/trace"
          }
        },
        "required": ["provenance"],
        "additionalProperties": true
      }
    },
    "competitive_intelligence": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "id": {"type": "string"},
          "competitor": {"type": "string"},
          "provenance": {
            "$ref": "_common.schema.json#/$defs/provenance"
          },
          "trace": {
            "$ref": "_common.schema.json#/$defs/trace"
          }
        },
        "required": ["provenance"],
        "additionalProperties": true
      }
    }
  },
  "additionalProperties": true
}
